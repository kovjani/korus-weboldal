<!DOCTYPE html>
<html lang="hu">
  <head>
    <%- include('../components/common_head') %>
    <title>Fellépések</title>
    <script src="/js/event_list.js"></script>
    <link rel="stylesheet" href="/css/style.css" />
  </head>

  <body>
