      <%- include('../components/search_bar') %>
      <a href="/api/events/0"><span class="material-icons">add</span></a>
      <div class="event-list">
        <% events.forEach((event) => { %>
        <%- include('../components/event_card', {event: event}); %>
        <% }); %>
      </div>
    </div>
  </body>
</html>
