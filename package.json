{
  "name": "korus-weboldal",
  "version": "1.0.0",
  "description": "Programrendszerek fejlesztése beadandó.",
  "repository": {
    "type": "git",
    "url": "korus-weboldal"
  },
  "license": "ISC",
  "author": "Kovács János András",
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "build:server": "tsc",
    "build:fe-ts": "esbuild src/public/ts/*.ts --outdir=dist/public/js --bundle --minify --platform=browser",
    "build:scss": "sass src/public/scss/event_list.scss dist/public/css/style.css",
    "build": "npm run build:server && npm run build:fe-ts && npm run build:scss && cp -r src/views dist/",
    "watch:server": "nodemon --exec \"node --loader ts-node/esm\" src/app.ts",
    "watch:fe-ts": "esbuild src/public/ts/*.ts --outdir=dist/public/js --bundle --watch",
    "watch:scss": "sass --watch src/public/scss/main.scss:dist/public/css/style.css",
    "watch": "grunt",
    "start": "node dist/app.js"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "mysql": "^2.18.1",
    "mysql2": "^3.20.0",
    "prettier": "^3.8.1",
    "sass": "^1.97.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.3",
    "grunt": "^1.6.1",
    "grunt-concurrent": "^3.0.0",
    "grunt-contrib-watch": "^1.1.0",
    "grunt-shell": "^4.0.0",
    "nodemon": "^3.1.7",
    "prettier-plugin-ejs": "^1.0.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
